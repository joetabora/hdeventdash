# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: server-only, for push cron (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Push cron: POST /api/cron/push-notifications with Authorization: Bearer <this value>
CRON_SECRET=your-long-random-secret

# Public site URL for notification links (production)
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# Firebase Web App (Project settings > General > Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloud Messaging > Web Push certificates (Key pair)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin — Project settings > Service accounts > Generate new private key
# On Vercel, base64-encode the JSON file: base64 -i serviceAccount.json | pbcopy
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Or single-line JSON (local only; too large for some hosts)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# --- AI (server-only): local Ollama via Next.js API routes ---
# Set AI_ENABLED=true after Ollama is reachable from the Next.js process.
AI_ENABLED=false
# Docker Compose (same network as service name `ollama`): http://ollama:11434
# Next in Docker Desktop reaching Ollama on the Mac host: http://host.docker.internal:11434 (not 127.0.0.1)
# LAN: use the machine that runs Ollama (not 127.0.0.1 unless Next runs on that same host), e.g. http://192.168.1.79:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
# Optional comma-separated allowlist; when unset only OLLAMA_DEFAULT_MODEL may be used.
# Examples: llama3.1:8b,mistral:latest,gemma3:4b,qwen2.5-coder:7b
# OLLAMA_ALLOWED_MODELS=
# Extra transient retries toward Ollama (0 disables; cap 5). Total attempts = 1 + AI_OLLAMA_RETRIES.
# AI_OLLAMA_RETRIES=1
# Optional comma-separated hostname allowlist for OLLAMA_BASE_URL (production hardening).
# OLLAMA_HOST_ALLOWLIST=ollama,127.0.0.1,localhost
# Minimum 180000 (3m) enforced; tune Cloudflare Tunnel ingress/origin timeouts to match long inference.
AI_REQUEST_TIMEOUT_MS=180000
AI_MAX_PROMPT_CHARS=48000
AI_MAX_COMPLETION_CHARS=24000
