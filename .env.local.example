# --- AI (server-only): direct local Ollama via OLLAMA_BASE_URL ---
# Set AI_ENABLED=true after Ollama is reachable from the Next.js process.
AI_ENABLED=false
# Same machine as Ollama (default when unset):
OLLAMA_BASE_URL=http://127.0.0.1:11434
# LAN example (Docker app → Ollama on another host):
# OLLAMA_BASE_URL=http://192.168.1.79:11434
# Docker Desktop: Next container → Ollama on Mac host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
# Optional comma-separated allowlist; when unset only OLLAMA_DEFAULT_MODEL may be used.
# OLLAMA_ALLOWED_MODELS=qwen3:8b,qwen2.5:7b-instruct
AI_OLLAMA_RETRIES=1
# Optional hostname allowlist for OLLAMA_BASE_URL (production hardening).
# Include every host you use, e.g. 127.0.0.1, localhost, host.docker.internal, 192.168.1.79
# OLLAMA_HOST_ALLOWLIST=127.0.0.1,localhost,host.docker.internal
# Minimum 90000 (90s) enforced.
AI_REQUEST_TIMEOUT_MS=90000
# Cap each Ollama generate so JSON returns before CDN/tunnel idle timeouts (~90s). Set 0 to disable.
AI_PROXY_SAFE_TIMEOUT_MS=75000
AI_MAX_TOKENS=1024
AI_DEFAULT_TEMPERATURE=0.7
AI_MAX_PROMPT_CHARS=48000
AI_MAX_COMPLETION_CHARS=24000
# AI_STREAMING_ENABLED=false
