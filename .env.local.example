# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: server-only, for push cron (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Push cron: POST /api/cron/push-notifications with Authorization: Bearer <this value>
CRON_SECRET=your-long-random-secret

# Public site URL for notification links (production)
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# Firebase Web App (Project settings > General > Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloud Messaging > Web Push certificates (Key pair)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin — Project settings > Service accounts > Generate new private key
# On Vercel, base64-encode the JSON file: base64 -i serviceAccount.json | pbcopy
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Or single-line JSON (local only; too large for some hosts)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# --- AI (server-only): direct local Ollama — no Open WebUI / OpenAI proxy ---
# Set AI_ENABLED=true after Ollama is reachable from the Next.js process.
AI_ENABLED=false
# Local Mac / same host: http://127.0.0.1:11434
# Docker Compose (service name `ollama`): http://ollama:11434
# Next in Docker Desktop reaching Ollama on the Mac host: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
# Optional comma-separated allowlist; when unset only OLLAMA_DEFAULT_MODEL may be used.
# OLLAMA_ALLOWED_MODELS=qwen3:8b,qwen2.5:7b
# Extra transient retries toward Ollama (0 disables; cap 5). Total attempts = 1 + AI_OLLAMA_RETRIES.
AI_OLLAMA_RETRIES=1
# Optional comma-separated hostname allowlist for OLLAMA_BASE_URL (production hardening).
# OLLAMA_HOST_ALLOWLIST=ollama,127.0.0.1,localhost
# Minimum 90000 (90s) enforced; tune Cloudflare Tunnel ingress/origin timeouts to match.
AI_REQUEST_TIMEOUT_MS=90000
# Ollama num_predict cap — keep modest on 6GB VRAM (default 2048).
AI_MAX_TOKENS=2048
AI_DEFAULT_TEMPERATURE=0.7
AI_MAX_PROMPT_CHARS=48000
AI_MAX_COMPLETION_CHARS=24000
# Set true to enable streaming helpers in ollama-client (API routes use non-streaming by default).
# AI_STREAMING_ENABLED=false
